# --- Contact form (Resend) ---------------------------------------------
# Create a key at https://resend.com. Until this is set, the contact form
# returns a friendly "not configured" error instead of sending.
RESEND_API_KEY=

# Where contact form submissions are delivered.
CONTACT_TO_EMAIL=drew@digitalmiddleground.com

# Must be a sender Resend allows for your account. Before you verify the
# binaural-studio.com domain in Resend, use their sandbox sender:
CONTACT_FROM_EMAIL="Binaural Studio <onboarding@resend.dev>"
